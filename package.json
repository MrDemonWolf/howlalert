{
  "name": "howlalert",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/node": "^22.13.14",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:server": "turbo -F server dev",
    "dev:docs": "turbo -F @howlalert/docs dev",
    "db:push": "turbo -F @howlalert/db db:push",
    "db:studio": "turbo -F @howlalert/db db:studio",
    "db:generate": "turbo -F @howlalert/db db:generate",
    "db:migrate": "turbo -F @howlalert/db db:migrate"
  },
  "dependencies": {
    "@howlalert/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@howlalert/config": "workspace:*",
    "@types/node": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.12"
}
