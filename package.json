{
	"name": "howlalert",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"typecheck": "turbo typecheck",
		"test": "turbo test",
		"lint": "eslint .",
		"clean": "turbo clean",
		"check": "eslint . && prettier --check .",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@vitest/coverage-v8": "^4.1.2",
		"bun-types": "^1.3.11",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-unused-imports": "^4.4.1",
		"prettier": "^3.8.1",
		"turbo": "^2.9.3",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	},
	"packageManager": "bun@1.3.10",
	"engines": {
		"node": ">=20"
	}
}
