{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"types": ["bun-types"],
		"jsx": "preserve",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
